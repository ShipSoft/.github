{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": ["config:recommended", ":enablePreCommit"],
  "schedule": ["every weekend"],
  "prConcurrentLimit": 5,
  "lockFileMaintenance": { "enabled": false },
  "customManagers": [
    {
      "customType": "regex",
      "description": "Update CMake FetchContent GIT_TAG versions (GitHub sources)",
      "managerFilePatterns": ["/CMakeLists\\.txt$/", "/\\.cmake$/"],
      "matchStrings": [
        "GIT_REPOSITORY\\s+https://github\\.com/(?<packageName>[\\w.-]+/[\\w.-]+?)(?:\\.git)?\\s+GIT_TAG\\s+(?<currentValue>[\\w./-]+)"
      ],
      "datasourceTemplate": "github-tags"
    }
  ],
  "packageRules": [
    {
      "description": "pixi conda deps: compare with conda versioning, not the manager's pep440 default",
      "matchManagers": ["pixi"],
      "matchDatasources": ["conda"],
      "versioning": "conda"
    },
    {
      "description": "Never auto-bump the pinned Python interpreter; the lock workflow handles in-series patches",
      "matchManagers": ["pixi"],
      "matchPackageNames": ["python"],
      "enabled": false
    },
    {
      "description": "Use loose versioning for CMake FetchContent (and other regex) tags",
      "matchManagers": ["custom.regex"],
      "versioning": "loose"
    }
  ]
}
